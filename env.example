# ── Backend ──
DATABASE_URL=postgresql://carrier_user:carrier_pass@db:5432/carrier_sales
API_KEY=your-secure-api-key-here
FMCSA_API_KEY=your-fmcsa-api-key-here
DEMO_MODE=true

# ── Railway deployment ──
# Railway sets PORT and DATABASE_URL automatically.
# Just set these:
# API_KEY=your-secure-api-key-here
# FMCSA_API_KEY=your-fmcsa-api-key-here
# DEMO_MODE=true

# ── Get FMCSA API key ──
# Free registration at: https://mobile.fmcsa.dot.gov/QCDevsite/docs/apiAccess
# Without this key, carrier verification falls back to mock data.
